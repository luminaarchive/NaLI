# NaLI by NatIve, environment variables
# Copy to .env.local and fill in.

# Supabase project URL, e.g. https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable/anon key (sb_publishable_... or legacy anon JWT)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Gemini API key (server-side only - used for RAG chat + embeddings)
# Get one free at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# SEO: search-engine ownership verification (optional, founder sets these).
# Google Search Console -> add property nalibynative.com -> "HTML tag" method ->
# copy the content value of the meta tag here, then redeploy + Verify, then
# submit https://nalibynative.com/sitemap.xml.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools -> add site -> "Meta tag" -> content value here.
NEXT_PUBLIC_BING_SITE_VERIFICATION=
