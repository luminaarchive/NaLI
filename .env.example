# NaLI by NatIve — environment variables
# Copy to .env.local and fill in. Both are PUBLIC (safe to ship to the browser);
# the subscribers table is protected by row-level security (insert-only for anon).

# Supabase project URL, e.g. https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable/anon key (sb_publishable_... or legacy anon JWT)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
