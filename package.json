{
  "name": "nali",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint src tests next.config.mjs eslint.config.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "precommit:check": "lint-staged --no-stash",
    "bench": "node tests/performance/reasoning-baseline.cjs",
    "typecheck": "tsc --noEmit",
    "typecheck:build": "tsc --noEmit -p tsconfig.build.json",
    "test:reasoning": "node --test tests/reasoning/operational-runtime.test.cjs",
    "test:longitudinal": "node --test tests/longitudinal/longitudinal-intelligence.test.cjs",
    "test:demo": "node --test tests/demo/public-species-demo.test.cjs",
    "test:field-intelligence": "node --test tests/field-intelligence/*.test.cjs",
    "test:fine-tuning": "node --test tests/fine-tuning/*.test.cjs",
    "test:golden": "node tests/golden-set/run-pipeline.cjs",
    "check:i18n": "node scripts/check-i18n-coverage.cjs",
    "smoke:feedback:prod": "node scripts/smoke-feedback-production.mjs",
    "smoke:export:prod": "node scripts/smoke-paid-export-production.mjs",
    "smoke:ai:prod": "node scripts/smoke-ai-generation.mjs",
    "payment:confirm:manual": "node scripts/confirm-manual-payment.mjs",
    "check:readiness:prod": "node -e \"fetch('https://naliai.vercel.app/api/system/readiness').then(r => r.json()).then(console.log).catch(console.error)\"",
    "verify": "npm run build && npm run typecheck && npm run check:i18n && npm run test:demo && npm run test:field-intelligence && npm run test:fine-tuning && npm run test:reasoning && npm run test:longitudinal && npm run test:golden",
    "seo:google-checklist": "node scripts/print-google-indexing-checklist.cjs",
    "validate:supabase": "node scripts/validate-supabase-live.cjs",
    "validate:rls": "node scripts/validate-rls.cjs",
    "validate:storage": "node scripts/validate-storage.cjs",
    "validate:vercel-env": "node scripts/print-vercel-env-checklist.cjs",
    "validate:production": "npm run validate:vercel-env && npm run validate:supabase && npm run validate:storage && npm run validate:rls",
    "agent:env-check": "node scripts/agent/check-env-readiness.mjs",
    "agent:git-check": "node scripts/agent/check-git-clean.mjs",
    "agent:prod-smoke": "node scripts/agent/check-production-routes.mjs",
    "agent:seo-smoke": "node scripts/agent/check-seo-routes.mjs",
    "agent:verify-fast": "node scripts/agent/verify-fast.mjs",
    "agent:verify-full": "node scripts/agent/verify-full.mjs"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@base-ui/react": "^1.4.1",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "docx": "^9.6.1",
    "exifr": "^7.1.3",
    "framer-motion": "^12.38.0",
    "h3-js": "^4.4.0",
    "inngest": "^4.2.6",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.511.0",
    "motion": "^12.39.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^3.2.0",
    "shadcn": "^4.8.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "agent-browser": "^0.26.0",
    "autoprefixer": "^10.0.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "playwright": "^1.60.0",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
