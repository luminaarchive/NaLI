{
  "name": "nali-by-native",
  "version": "0.1.0",
  "private": true,
  "description": "NaLI by NatIve, Jurnal Riset Terbuka Indonesia untuk alam, sejarah, dan investigasi berbasis sumber.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check:editorial": "node scripts/validate-editorial-content.mjs",
    "check:article-images": "node scripts/check-article-images.mjs",
    "check:routes": "node scripts/check-public-routes.mjs",
    "check:metadata": "node scripts/check-metadata-integrity.mjs",
    "check:covers": "node scripts/check-cover-integrity.mjs",
    "check:a11y": "node scripts/check-accessibility.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:schema": "node scripts/check-schema.mjs",
    "check:legal": "node scripts/check-legal.mjs",
    "check:all": "npm run check:schema && npm run check:editorial && npm run check:legal && npm run check:a11y && npm run check:lab-isolation",
    "check:lab-isolation": "node scripts/check-lab-isolation.mjs",
    "sync:articles": "node scripts/sync-articles.mjs && node scripts/emit-on-sync.mjs && npm run graph:generate",
    "sync:articles:dry": "node scripts/sync-articles.mjs --dry-run",
    "graph:generate": "node scripts/generate-graph.mjs",
    "harvest:pustaka": "node scripts/mine/harvest-oa-to-supabase.mjs",
    "social": "node scripts/social/kit.mjs",
    "ingest": "node --env-file=.env.local scripts/ingest-embeddings.mjs",
    "detect:contradictions": "node --env-file=.env.local scripts/detect-contradictions.mjs",
    "lab:harvest:gbif": "node scripts/lab/harvest-gbif.mjs",
    "lab:harvest:inat": "node scripts/lab/harvest-inat.mjs",
    "lab:harvest:iucn": "node --env-file=.env.local scripts/lab/harvest-iucn.mjs",
    "lab:build-leads": "node --env-file=.env.local scripts/lab/build-leads.mjs",
    "lab:ghost:inat": "node scripts/lab/ghost/harvest-inat-needsid.mjs",
    "lab:ghost:xenocanto": "node --env-file=.env.local scripts/lab/ghost/harvest-xenocanto.mjs",
    "lab:ghost:youtube": "node --env-file=.env.local scripts/lab/ghost/harvest-youtube.mjs",
    "lab:build-signals": "node --env-file=.env.local scripts/lab/ghost/build-signals.mjs"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.0",
    "@google/generative-ai": "^0.24.1",
    "@paper-design/shaders-react": "^0.0.76",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^7.0.2",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "fuse.js": "^7.4.2",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "lucide-react": "^1.18.0",
    "next": "^14.2.30",
    "next-mdx-remote": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "reading-time": "^1.5.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.30",
    "postcss": "^8.5.15",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
